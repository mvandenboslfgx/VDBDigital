# Supabase DB: use connection pooler (port 6543) for runtime; direct for migrations.
# DATABASE_URL = pooler (port 6543); DIRECT_URL = direct connection (port 5432) for prisma migrate.
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-REGION.supabase.com:5432/postgres"

# Supabase Auth (from Supabase dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Optional: server-side only (admin, service tasks). Never expose to client.
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# SMTP for emails (audit report, review requests, client account)
SMTP_HOST="smtp.your-provider.com"
SMTP_PORT="587"
SMTP_USER="your-smtp-username"
SMTP_PASS="your-smtp-password"
SMTP_FROM="noreply@vdbdigital.nl"
# Contactformulier en notificaties gaan naar dit adres (aanbevolen: algemeen@vdbdigital.nl)
ADMIN_EMAIL="algemeen@vdbdigital.nl"

# Stripe (subscriptions: Starter €29, Growth €79, Agency €199; legacy PRO/BUSINESS map to starter/growth)
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_PRICE_ID_STARTER="price_..."
STRIPE_PRICE_ID_GROWTH="price_..."
STRIPE_PRICE_ID_AGENCY="price_..."
# Legacy (optional): STRIPE_PRICE_ID_PRO, STRIPE_PRICE_ID_BUSINESS

JWT_SECRET="complex-random-jwt-secret"

OPENAI_API_KEY="sk-proj-..."
RESEND_API_KEY="re_..."

# Optional: PageSpeed Insights in website audit (elke scan ~5–10 sec trager)
# PAGESPEED_ENABLED=true
# PAGESPEED_API_KEY="..."   # Google Cloud API key voor hoger quota

# Optional: platform owner emails (comma-separated). Alleen in .env zetten; .env staat in .gitignore en wordt nooit gecommit.
OWNER_EMAILS=email1@voorbeeld.nl,email2@voorbeeld.nl

# Optional: monthly hosting cost (EUR) for owner finance dashboard
HOSTING_COST_EUR=0

# Optional: base URL for redirects and emails
SITE_URL="https://www.vdbdigital.nl"

# Optional: Redis for cache, rate limit, and audit queue (BullMQ)
# REDIS_URL="redis://localhost:6379"

# Optional: Cloudflare Turnstile (bot protection for contact, register)
TURNSTILE_SECRET_KEY=""
# Trustpilot review link (used in review request emails and /reviews page)
TRUSTPILOT_URL="https://www.trustpilot.com/review/vdb.digital"
NEXT_PUBLIC_TRUSTPILOT_URL="https://www.trustpilot.com/review/vdb.digital"
