# VDB Digital — Environment variables
# Copy to .env and fill in real values. Never commit .env.

# Database (Supabase: pooler for runtime; DIRECT_URL optional for migrations)
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres"
# Optional (recommended for migrations if your host requires non-pooler):
# DIRECT_URL="postgresql://postgres.PROJECT:PASSWORD@aws-REGION.supabase.com:5432/postgres"

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# Add to Supabase Dashboard → Auth → URL Configuration → Redirect URLs:
#   http://localhost:3000/auth/callback
#   https://www.vdbdigital.nl/auth/callback

# Stripe (use NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY for client; STRIPE_PUBLIC_KEY optional alias)
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_PRICE_ID_STARTER="price_..."
STRIPE_PRICE_ID_GROWTH="price_..."
STRIPE_PRICE_ID_AGENCY="price_..."

# OpenAI (audit, optimizer)
OPENAI_API_KEY="sk-proj-..."

# Email (SMTP or Resend)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@vdbdigital.nl"
RESEND_API_KEY="re_..."

# App
JWT_SECRET="random-32-char-secret"
SITE_URL="https://www.vdbdigital.nl"
ADMIN_EMAIL="algemeen@vdbdigital.nl"
OWNER_EMAILS="owner@example.com"

# Redis (optional: rate limit + cache; in-memory fallback when unset)
REDIS_URL="redis://localhost:6379"

# Monitoring (optional)
SENTRY_DSN="https://...@sentry.io/..."
NEXT_PUBLIC_SENTRY_DSN="https://...@sentry.io/..."
