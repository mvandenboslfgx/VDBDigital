# VDB Digital — env template (geen echte waarden; kopieer naar .env en vul in)
# .env wordt nooit gecommit (.gitignore)

# Database (Supabase: pooler voor runtime, direct voor migrations)
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-REGION.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres.PROJECT:PASSWORD@aws-REGION.supabase.com:5432/postgres"

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Stripe
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_PRICE_ID_STARTER="price_..."
STRIPE_PRICE_ID_GROWTH="price_..."
STRIPE_PRICE_ID_AGENCY="price_..."

# OpenAI (voor audit, optimizer, etc.)
OPENAI_API_KEY="sk-proj-..."

# App
JWT_SECRET="random-secret"
SITE_URL="https://www.vdbdigital.nl"
ADMIN_EMAIL="algemeen@vdbdigital.nl"
