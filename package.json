{
  "name": "vdb-digital",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "postinstall": "node scripts/prisma-generate.js",
    "build": "next build",
    "build:prod": "npm run validate-env && next build",
    "validate-env": "node scripts/validate-env.js",
    "predeploy": "npm run validate-env && npm run build",
    "start": "next start",
    "lint": "eslint .",
    "clean:build-cache": "node scripts/clean-build-cache.js",
    "typecheck": "tsc --noEmit",
    "audit:deps": "npm audit --audit-level=critical",
