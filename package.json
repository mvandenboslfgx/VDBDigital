    "nodemailer": "^8.0.1",
    "openai": "^6.26.0",
    "pdf-lib": "^1.17.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.54.0",
    "recharts": "^2.15.0",
