    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "audit:worker": "tsx scripts/run-audit-worker.ts",
    "fix:worker": "tsx scripts/run-fix-worker.ts",
    "ads:metrics:worker": "tsx scripts/run-ad-metrics-worker.ts",
    "commerce:worker": "tsx scripts/run-commerce-worker.ts",
    "test:audit-scoring": "tsx modules/audit/__tests__/scoring.test.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "7.5.0",
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "bullmq": "^5.71.0",
    "cheerio": "latest",
    "cmdk": "^1.0.0",
    "framer-motion": "latest",
    "ioredis": "^5.10.1",
    "jose": "latest",
    "next": "latest",
    "nodemailer": "latest",
    "openai": "latest",
